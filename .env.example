# URL base del backend SIGA (Spring Boot). El login Google OAuth2 y /api/me viven aquí.
# Copia este archivo a `.env.local` (gitignored) y ajusta según el entorno:
#
#   Local  : http://localhost:8081   (el 8080 suele estar ocupado por Apache/httpd)
#   Vercel : https://TU-BACKEND.onrender.com   (define VITE_API_BASE_URL en el dashboard)
VITE_API_BASE_URL=http://localhost:8081
